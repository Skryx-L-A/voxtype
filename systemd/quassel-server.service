[Unit]
Description=Whisper.cpp speech-to-text server (for Quassel)

[Service]
Type=simple
EnvironmentFile=-%h/.config/quassel/server.env
ExecStart=/bin/sh -c 'exec "${SERVER_BIN:-whisper-server}" -m "$MODEL_PATH" -t "${WHISPER_THREADS:-4}" --host 127.0.0.1 --port 8765 -l auto -nt'
Restart=on-failure
RestartSec=3
