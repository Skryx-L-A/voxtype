[Desktop Entry]
Type=Application
Name=Diktat
GenericName=Spracheingabe Ein/Aus
Comment=Spracheingabe ein-/ausschalten (Strg+Meta halten oder doppelt tippen)
Keywords=Diktat;Spracheingabe;Mikrofon;Whisper;dictation;voice;speech
Exec=@HOME@/.local/bin/dictate-gui
Icon=audio-input-microphone
Terminal=false
StartupWMClass=de.lillebor.diktat
Actions=start;stop;

[Desktop Action start]
Name=Diktat starten
Exec=@HOME@/.local/bin/dictate-ctl start

[Desktop Action stop]
Name=Diktat stoppen
Exec=@HOME@/.local/bin/dictate-ctl stop
