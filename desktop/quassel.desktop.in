[Desktop Entry]
Type=Application
Name=Quassel
GenericName=Voice Typing
Comment=Local voice typing — hold Ctrl+Meta, speak, release / Lokale Spracheingabe
Keywords=Quassel;voice;dictation;speech;typing;Diktat;Spracheingabe;Mikrofon;Whisper
Exec=@HOME@/.local/bin/quassel-type
Icon=quassel-voice
Terminal=false
StartupWMClass=quassel
Actions=start;stop;

[Desktop Action start]
Name=Turn on / Einschalten
Exec=@HOME@/.local/bin/quassel-ctl start

[Desktop Action stop]
Name=Turn off / Ausschalten
Exec=@HOME@/.local/bin/quassel-ctl stop
