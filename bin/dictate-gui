#!/usr/bin/env python3
"""Kleines Fenster zum Ein-/Ausschalten des Diktats.

Das Fenster ist nur eine Fernbedienung für die systemd-Dienste
(dictate-daemon + whisper-server) — Schließen des Fensters lässt das
Diktat unverändert weiterlaufen.
"""
import subprocess

import gi
gi.require_version("Gtk", "4.0")
from gi.repository import GLib, Gtk


def daemon_active():
    return subprocess.run(
        ["systemctl", "--user", "is-active", "--quiet", "dictate-daemon"],
        check=False).returncode == 0


def set_active(on):
    action = "start" if on else "stop"
    subprocess.run(
        ["systemctl", "--user", action, "dictate-daemon", "whisper-server"],
        check=False)


class DiktatApp(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="de.lillebor.diktat")
        self._updating = False

    def do_activate(self):
        win = self.props.active_window
        if win:
            win.present()
            return

        win = Gtk.ApplicationWindow(
            application=self, title="Diktat", resizable=False,
            default_width=400)

        box = Gtk.Box(
            orientation=Gtk.Orientation.VERTICAL, spacing=14,
            margin_top=24, margin_bottom=24, margin_start=28, margin_end=28)
        win.set_child(box)

        self.status = Gtk.Label()
        self.status.set_wrap(True)
        self.status.set_justify(Gtk.Justification.CENTER)
        box.append(self.status)

        self.switch = Gtk.Switch(halign=Gtk.Align.CENTER)
        self.switch.connect("state-set", self.on_switch)
        box.append(self.switch)

        hint = Gtk.Label()
        hint.set_wrap(True)
        hint.set_justify(Gtk.Justification.CENTER)
        hint.set_markup(
            "<small>Strg+Meta <b>halten</b> = sprechen, loslassen fügt ein\n"
            "Strg+Meta <b>2× tippen</b> = freihändig, 1× drücken fügt ein\n\n"
            "Dieses Fenster kann geschlossen werden —\n"
            "das Diktat läuft im Hintergrund weiter.</small>")
        box.append(hint)

        self.refresh()
        GLib.timeout_add(2000, self.refresh)
        win.present()

    def refresh(self):
        on = daemon_active()
        self._updating = True
        self.switch.set_active(on)
        self._updating = False
        if on:
            self.status.set_markup(
                "<span size='x-large' foreground='#2e9e2e'><b>● Diktat ist AN</b></span>")
        else:
            self.status.set_markup(
                "<span size='x-large' foreground='#888888'><b>○ Diktat ist AUS</b></span>")
        return True  # Timer weiterlaufen lassen

    def on_switch(self, _switch, state):
        if not self._updating:
            set_active(state)
            self.refresh()
        return False


if __name__ == "__main__":
    DiktatApp().run()
